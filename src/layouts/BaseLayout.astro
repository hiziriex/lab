---
import "../styles/theme.css";
import "../styles/base.css";
import "../styles/layout.css";
import "../styles/components.css";
import "../styles/markdown.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    />

    <script
      defer
      src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        if (window.renderMathInElement) {
          window.renderMathInElement(document.body, {
            delimiters: [
              { left: "$$", right: "$$", display: true },
              { left: "$", right: "$", display: false }
            ]
          });
        }
      });
    </script>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <div class="site-brand">
          <a class="site-title-link" href={base}>
            <h1 class="site-title">hiziriex lab</h1>
          </a>
          <p class="site-subtitle">技術計算ツールと備忘録</p>
        </div>

        <nav class="main-nav">
          <a href={base}>TOP</a>
          <a href={`${base}/tools/`}>計算ツール</a>
          <a href={`${base}/articles/`}>技術記事</a>
        </nav>
      </div>
    </header>

    <main class="page-main">
      <slot />
    </main>
  </body>
</html>