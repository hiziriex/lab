---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="hiziriex lab | 技術計算ツールと備忘録">
  <div class="page-top">
    <header class="site-header">
      <div class="container-top header-inner">
        <div class="site-brand">
          <h1 class="site-title">hiziriex lab</h1>
          <p class="site-subtitle">技術計算ツールと備忘録</p>
        </div>

        <nav class="main-nav">
          <a href="/">TOP</a>
          <a href="/tools/">計算ツール</a>
          <a href="/articles/">技術記事</a>
        </nav>
      </div>
    </header>

    <main class="page-main container-top">
      <section class="page-section">
        <h2>このサイトについて</h2>
        <p>
          電気電子系の計算ツールと、実効値などの技術用語・応用についての備忘録をまとめるサイトです。
        </p>
      </section>

      <section class="page-section">
        <h2>計算ツール</h2>
        <div class="category-grid">
          <div class="card">
            <h3>抵抗回路</h3>
            <ul class="link-list">
              <li><a href="/tools/voltage-divider/">抵抗分圧</a></li>
            </ul>
          </div>

          <div class="card">
            <h3>波形計算</h3>
            <ul class="link-list">
              <li><a href="#">実効値計算</a></li>
              <li><a href="#">実効値の加算</a></li>
            </ul>
          </div>
        </div>
      </section>

      <section class="page-section">
        <h2>技術記事</h2>
        <div class="category-grid">
          <div class="card">
            <h3>基礎</h3>
            <ul class="link-list">
              <li><a href="/articles/rms/">実効値とは</a></li>
            </ul>
          </div>

          <div class="card">
            <h3>応用</h3>
            <ul class="link-list">
              <li><a href="#">実効値の加算</a></li>
            </ul>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>