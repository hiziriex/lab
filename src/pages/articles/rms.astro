<BaseLayout title="実効値とは | hiziriex lab">
  <div class="page-article">
    <header class="site-header">
      <div class="container-article header-inner">
        <div class="site-brand">
          <h1 class="site-title">hiziriex lab</h1>
          <p class="site-subtitle">技術計算ツールと備忘録</p>
        </div>

        <nav class="main-nav">
